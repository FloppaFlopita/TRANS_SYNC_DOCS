@startuml
!theme plain
skinparam rectangle {
    BackgroundColor #85bbf0
    BorderColor #438dd5
}

title Nivel 3: Componentes - Microservicio de Auditoría

rectangle "Cola de Mensajes / API" as api #438dd5

package "Microservicio de Liquidación" {
    rectangle "Auditoría Controller\n[REST Controller]\n\nRecibe eventos de ventas." as controller
    rectangle "Cierre de Caja Service\n[Service]\n\nSuma ingresos por vendedor/chofer\ny guarda el historial de acciones." as service
    rectangle "Auditoría Repository\n[Repository]\n\nRegistro inmutable (Solo escritura)." as repository
}

database "BD Auditoría" as bd_auditoria #2b78e4

api --> controller : POST /registro-venta
controller --> service : Calcula ingresos
service --> repository : Guarda log
repository --> bd_auditoria : SQL
@enduml