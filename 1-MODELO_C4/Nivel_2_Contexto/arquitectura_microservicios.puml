@startuml
left to right direction
skinparam node {
    BackgroundColor #f4f4f4
    BorderColor #333333
}

title Anexo H: Representación conceptual de Microservicios

node "Clientes (Frontend)" {
    [App Web (Terminales)]
    [App Móvil (Conductores)]
}

node "Punto de Entrada" {
    [API Gateway]
}

node "Ecosistema de Microservicios (Backend)" {
    [MS Autenticación]
    [MS Usuarios]
    [MS Pasajes]
    [MS Encomiendas]
    [MS Liquidación]
}

database "Bases de Datos Independientes" {
    (BD Auth)
    (BD Usuarios)
    (BD Pasajes)
    (BD Encomiendas)
    (BD Liquidación)
}

[App Web (Terminales)] --> [API Gateway]
[App Móvil (Conductores)] --> [API Gateway]

[API Gateway] --> [MS Autenticación]
[API Gateway] --> [MS Usuarios]
[API Gateway] --> [MS Pasajes]
[API Gateway] --> [MS Encomiendas]
[API Gateway] --> [MS Liquidación]

[MS Autenticación] --> (BD Auth)
[MS Usuarios] --> (BD Usuarios)
[MS Pasajes] --> (BD Pasajes)
[MS Encomiendas] --> (BD Encomiendas)
[MS Liquidación] --> (BD Liquidación)

@enduml