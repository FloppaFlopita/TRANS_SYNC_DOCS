@startuml
!theme plain
skinparam rectangle {
    BackgroundColor #438dd5
    FontColor white
    BorderColor #1168bd
}
skinparam database {
    BackgroundColor #2b78e4
    FontColor white
}

title Nivel 2: Diagrama de Contenedores - TRANS-SYNC (Monolito)

actor "Despachador" as despachador
actor "Conductor / Dueño" as movil_user

rectangle "Aplicación Web (Terminales)\n[Contenedor: React/Angular]" as web
rectangle "Aplicación Móvil\n[Contenedor: Flutter/Android]" as app

rectangle "Aplicación Monolítica TRANS-SYNC\n[Contenedor: Spring Boot]\n\nGestiona toda la lógica de negocio\n(Auth, Pasajes, Encomiendas)" as monolito

database "Base de Datos Unificada\n[PostgreSQL]" as bd_central

despachador --> web : Usa (HTTPS)
movil_user --> app : Usa (HTTPS)

web --> monolito : Peticiones API REST (JSON/HTTPS)
app --> monolito : Peticiones API REST (JSON/HTTPS)

monolito --> bd_central : Lee/Escribe (SQL)
@enduml