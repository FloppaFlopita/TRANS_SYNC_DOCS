@startuml
!theme plain
skinparam componentStyle uml2

title Diagrama de Componentes UML - Conexión App Móvil (Arquitectura Monolítica)

package "Capa Cliente" {
  component "App Móvil (Conductores)" as appMovil
}

package "Capa Servidor (TRANS-SYNC Monolito)" {

  component "Módulo\nAutenticación" as modAuth {
    port " " as pAuth
  }

  component "Módulo\nEncomiendas" as modEnc {
    port " " as pEnc
  }

  interface "I_Seguridad (JWT)" as iAuth
  interface "I_Logística (REST)" as iEnc
}

' Conexiones de la app directamente a las interfaces del monolito
appMovil -down-> iAuth : <<usa>> JSON/HTTPS
appMovil -down-> iEnc : <<usa>> JSON/HTTPS

' Módulos proveyendo interfaces (el enchufe)
iAuth - pAuth
iEnc - pEnc

@enduml